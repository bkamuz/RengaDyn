        }
      ],
      "FunctionSignature": "Autodesk.DesignScript.Geometry.CoordinateSystem.ByOrigin@Autodesk.DesignScript.Geometry.Point",
      "Replication": "Auto",
      "Description": "Create a CoordinateSystem with origin at input Point, with X and Y Axes set as WCS X and Y Axes.\n\nCoordinateSystem.ByOrigin (origin: Point = Autodesk.DesignScript.Geometry.Point.ByCoordinates(0, 0, 0)): CoordinateSystem"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "d25a1dc4192941c6a54bcb285ce68c63",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "6e9ec73c386843e49a02d773dab760ae",
          "Name": "geometry",
          "Description": "Autodesk.DesignScript.Geometry.Geometry",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "daadf855b1934015a88d1e220ab656c9",
          "Name": "cs",
          "Description": "CoordinateSystem",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "8b1e866f8a13414392f9cca1f0081a2c",
          "Name": "Geometry",
          "Description": "Transformed geometry",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "FunctionSignature": "Autodesk.DesignScript.Geometry.Geometry.Transform@Autodesk.DesignScript.Geometry.CoordinateSystem",
      "Replication": "Longest",
      "Description": "Transforms geometry by the given transform of CoordinateSystem\n\nGeometry.Transform (cs: CoordinateSystem): Geometry"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# python\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nEPS = 1e-6\r\n\r\ndef uniq_sorted(vals, tol=1e-6):\r\n    vals = sorted(vals); out = []\r\n    for v in vals:\r\n        if not out or abs(v - out[-1]) > tol: out.append(v)\r\n    return out\r\n\r\ndef get_local_cs(pc):\r\n    # Нормализация вектора вручную (в некоторых сборках нет Normalize/Normalized)\r\n    def unit(v):\r\n        try:\r\n            L = v.Length\r\n        except:\r\n            # если внезапно пришёл не Vector\r\n            return v\r\n        if L == 0: \r\n            return v\r\n        return Vector.ByCoordinates(v.X / L, v.Y / L, v.Z / L)\r\n\r\n    # 1) пробуем через Surface.ByPatch\r\n    try:\r\n        srf = Surface.ByPatch(pc)\r\n        cs0 = srf.CoordinateSystemAtParameter(0.5, 0.5)\r\n        try: srf.Dispose()\r\n        except: pass\r\n    except:\r\n        # 2) fallback: best-fit plane\r\n        pts = [c.StartPoint for c in pc.Curves()]\r\n        pl = Plane.ByBestFitThroughPoints(pts)\r\n        cs0 = CoordinateSystem.ByPlane(pl)\r\n        for p in pts:\r\n            try: p.Dispose()\r\n            except: pass\r\n        try: pl.Dispose()\r\n        except: pass\r\n\r\n    # 3) собираем оси как СВОЙСТВА (не вызываем!)\r\n    o = cs0.Origin\r\n    x = unit(cs0.XAxis)\r\n    y = unit(cs0.YAxis)\r\n    z = unit(cs0.ZAxis)\r\n\r\n    # 4) возвращаем корректную КС\r\n    return CoordinateSystem.ByOriginVectors(o, x, y, z)\r\n\r\ndef to_local_point(pt, cs):\r\n    p = pt.Transform(cs.Inverse())\r\n    return p.X, p.Y, p.Z\r\n\r\ndef boundary_xy_local(pc, cs):\r\n    verts = []\r\n    for crv in pc.Curves():\r\n        x,y,_ = to_local_point(crv.StartPoint, cs)\r\n        verts.append((x,y))\r\n    xe, ye, _ = to_local_point(pc.Curves()[-1].EndPoint, cs)\r\n    if abs(verts[0][0]-xe)>EPS or abs(verts[0][1]-ye)>EPS:\r\n        verts.append((xe,ye))\r\n    return verts\r\n\r\n# --- winding number (устойчивее на вершинах) ---\r\ndef wn_point_in_poly(px, py, V, eps=1e-9):\r\n    wn = 0\r\n    n = len(V)-1\r\n    for i in range(n):\r\n        x1,y1 = V[i]; x2,y2 = V[i+1]\r\n        # точка на ребре\r\n        if (min(x1,x2)-eps <= px <= max(x1,x2)+eps and\r\n            min(y1,y2)-eps <= py <= max(y1,y2)+eps):\r\n            if abs((x2-x1)*(py-y1) - (y2-y1)*(px-x1)) <= eps:\r\n                return True\r\n        if y1 <= py:\r\n            if y2 > py and (x2-x1)*(py-y1) - (y2-y1)*(px-x1) > 0: wn += 1\r\n        else:\r\n            if y2 <= py and (x2-x1)*(py-y1) - (y2-y1)*(px-x1) < 0: wn -= 1\r\n    return wn != 0\r\n\r\ndef orient(ax,ay,bx,by,cx,cy):\r\n    return (bx-ax)*(cy-ay) - (by-ay)*(cx-ax)\r\n\r\ndef segments_intersect(a,b,c,d, tol=1e-9, touch_ok=True):\r\n    ax,ay=a; bx,by=b; cx,cy=c; dx,dy=d\r\n    o1 = orient(ax,ay,bx,by,cx,cy); o2 = orient(ax,ay,bx,by,dx,dy)\r\n    o3 = orient(cx,cy,dx,dy,ax,ay); o4 = orient(cx,cy,dx,dy,bx,by)\r\n    if (o1*o2 < -tol and o3*o4 < -tol): return True\r\n    def onseg(p,q,r):\r\n        px,py=p; qx,qy=q; rx,ry=r\r\n        return (min(px,rx)-tol <= qx <= max(px,rx)+tol and min(py,ry)-tol <= qy <= max(py,ry)+tol)\r\n    if abs(o1)<=tol and onseg(a,c,b): return not touch_ok\r\n    if abs(o2)<=tol and onseg(a,d,b): return not touch_ok\r\n    if abs(o3)<=tol and onseg(c,a,d): return not touch_ok\r\n    if abs(o4)<=tol and onseg(c,b,d): return not touch_ok\r\n    return False\r\n\r\ndef rect_inside_strict(x0,y0,x1,y1, V):\r\n    # динамический inset от размера ячейки\r\n    w = abs(x1-x0); h = abs(y1-y0)\r\n    fc = max(0.008, 0.5*EPS/max(w,h,1.0))  # ~0.8% или чуть больше эпсилон/размер\r\n    fe = fc*0.5\r\n    cx,cy = 0.5*(x0+x1), 0.5*(y0+y1)\r\n    # углы + середины рёбер, сдвинутые внутрь\r\n    corners = [(x0+(cx-x0)*fc, y0+(cy-y0)*fc),\r\n               (x1+(cx-x1)*fc, y0+(cy-y0)*fc),\r\n               (x1+(cx-x1)*fc, y1+(cy-y1)*fc),\r\n               (x0+(cx-x0)*fc, y1+(cy-y1)*fc)]\r\n    edges = [(0.5*(x0+x1)+(cx-0.5*(x0+x1))*fe, y0+(cy-y0)*fe),\r\n             (x1+(cx-x1)*fe, 0.5*(y0+y1)+(cy-0.5*(y0+y1))*fe),\r\n             (0.5*(x0+x1)+(cx-0.5*(x0+x1))*fe, y1+(cy-y1)*fe),\r\n             (x0+(cx-x0)*fe, 0.5*(y0+y1)+(cy-0.5*(y0+y1))*fe)]\r\n    if not all(wn_point_in_poly(px,py,V) for (px,py) in corners+edges+[ (cx,cy) ]):\r\n        return False\r\n    # рёбра прямоугольника не должны пересекать границу (кроме касания)\r\n    re = [((x0,y0),(x1,y0)), ((x1,y0),(x1,y1)), ((x1,y1),(x0,y1)), ((x0,y1),(x0,y0))]\r\n    for i in range(len(V)-1):\r\n        e = (V[i], V[i+1])\r\n        for r in re:\r\n            if segments_intersect(r[0], r[1], e[0], e[1], tol=1e-9, touch_ok=True):\r\n                # легкое вдвигание внутрь и повторная проверка\r\n                (px1,py1),(px2,py2) = r\r\n                px1i,py1i = (px1+(cx-px1)*1e-4, py1+(cy-py1)*1e-4)\r\n                px2i,py2i = (px2+(cx-px2)*1e-4, py2+(cy-py2)*1e-4)\r\n                if segments_intersect((px1i,py1i),(px2i,py2i), e[0], e[1], tol=1e-9, touch_ok=True):\r\n                    return False\r\n    return True\r\n\r\n# ---------- Inputs ----------\r\nboundaries = IN[0] if len(IN)>0 else None\r\nsplitters_in = IN[1] if len(IN)>1 else None\r\nif splitters_in and not isinstance(splitters_in, list): splitters_in=[splitters_in]\r\n\r\n# normalize boundaries to a list so we can accept single or multiple inputs\r\nif boundaries is None:\r\n    OUT = []\r\nelse:\r\n    if not isinstance(boundaries, list):\r\n        boundaries = [boundaries]\r\n\r\n    all_zones = []\r\n    for boundary in boundaries:\r\n        if not boundary:\r\n            continue\r\n        cs = get_local_cs(boundary)\r\n        V = boundary_xy_local(boundary, cs)\r\n        if V[0]!=V[-1]: V.append(V[0])\r\n\r\n        # уровни: все X/Y вершин + из сплиттеров (поддержка линий и точек)\r\n        x_levels = [x for x,_ in V]\r\n        y_levels = [y for _,y in V]\r\n        if splitters_in:\r\n            for g in splitters_in:\r\n                if isinstance(g, Curve):\r\n                    x1,y1,_=to_local_point(g.StartPoint, cs); x2,y2,_=to_local_point(g.EndPoint, cs)\r\n                    if abs(x1-x2)<1e-6 and abs(y1-y2)<1e-6:\r\n                        x_levels.append(x1); y_levels.append(y1)\r\n                    else:\r\n                        if abs(x1-x2)<1e-6: x_levels.append(x1)\r\n                        if abs(y1-y2)<1e-6: y_levels.append(y1)\r\n                elif isinstance(g, Point):\r\n                    x,y,_=to_local_point(g, cs); x_levels.append(x); y_levels.append(y)\r\n\r\n        x_levels = uniq_sorted(x_levels, EPS)\r\n        y_levels = uniq_sorted(y_levels, EPS)\r\n\r\n        # генерим зоны\r\n        zones=[]\r\n        for yi in range(len(y_levels)-1):\r\n            y0,y1 = y_levels[yi], y_levels[yi+1]\r\n            for xi in range(len(x_levels)-1):\r\n                x0,x1 = x_levels[xi], x_levels[xi+1]\r\n                if rect_inside_strict(x0,y0,x1,y1, V):\r\n                    bl=Point.ByCartesianCoordinates(cs,x0,y0,0)\r\n                    br=Point.ByCartesianCoordinates(cs,x1,y0,0)\r\n                    tr=Point.ByCartesianCoordinates(cs,x1,y1,0)\r\n                    tl=Point.ByCartesianCoordinates(cs,x0,y1,0)\r\n                    zones.append(PolyCurve.ByPoints([bl,br,tr,tl,bl]))\r\n        all_zones.extend(zones)\r\n\r\n    OUT = all_zones",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "596ebaaebf044ffebb680a59a29a1802",
