      "Code": "has_points;"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python script\r\n# Split a closed polycurve (polygon) into two polygons of equal area.\r\n# The split line is parallel to the longest polygon edge.\r\n# Inputs:\r\n#   IN[0] : polygon (Autodesk.DesignScript Geometry Polygon / PolyCurve) or list of points\r\n# Output:\r\n#   OUT : dict or list of dicts with keys {\"polyA\",\"polyB\",\"sepLine\"}\r\n\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Polygon, PolyCurve, Line\r\nimport math\r\n\r\n# read input\r\nsrc = IN[0]\r\n\r\n# helpers to extract 2D point tuples from several possible input shapes\r\ndef to_point_list(obj):\r\n    try:\r\n        if isinstance(obj, list) and len(obj)>0 and hasattr(obj[0], 'X'):\r\n            return [(p.X, p.Y) for p in obj]\r\n    except:\r\n        pass\r\n    try:\r\n        pts = []\r\n        if hasattr(obj, \"Vertices\"):\r\n            for v in obj.Vertices:\r\n                pts.append((v.X, v.Y))\r\n            return pts\r\n        if hasattr(obj, \"Points\"):\r\n            for v in obj.Points:\r\n                pts.append((v.X, v.Y))\r\n            return pts\r\n    except:\r\n        pass\r\n    try:\r\n        if hasattr(obj, \"Coordinates\"):\r\n            return [(c.X, c.Y) for c in obj.Coordinates]\r\n    except:\r\n        pass\r\n    if isinstance(obj, list) and len(obj)>0 and isinstance(obj[0], (tuple, list)):\r\n        return [(float(x), float(y)) for x,y in obj]\r\n    return None\r\n\r\ndef sub(a,b): return (a[0]-b[0], a[1]-b[1])\r\ndef add(a,b): return (a[0]+b[0], a[1]+b[1])\r\ndef mul(a,s): return (a[0]*s, a[1]*s)\r\ndef dot(a,b): return a[0]*b[0] + a[1]*b[1]\r\ndef length(a): return math.hypot(a[0], a[1])\r\n\r\ndef polygon_area(poly):\r\n    a = 0.0\r\n    for i in range(len(poly)-1):\r\n        x1,y1 = poly[i]\r\n        x2,y2 = poly[i+1]\r\n        a += x1*y2 - x2*y1\r\n    return abs(a) * 0.5\r\n\r\ndef clip_halfspace(poly, nvec, t):\r\n    res = []\r\n    for i in range(len(poly)-1):\r\n        P = poly[i]\r\n        Q = poly[i+1]\r\n        dP = dot(nvec, P) - t\r\n        dQ = dot(nvec, Q) - t\r\n        if dP <= 0:\r\n            res.append(P)\r\n        if dP * dQ < 0:\r\n            s = dP / (dP - dQ)\r\n            inter = add(P, mul(sub(Q,P), s))\r\n            res.append(inter)\r\n    if len(res) > 0 and res[0] != res[-1]:\r\n        res.append(res[0])\r\n    return res\r\n\r\ndef make_polycurve_from_xy(xylist):\r\n    if not xylist or len(xylist) < 4:\r\n        return None\r\n    points = [Point.ByCoordinates(x,y,0) for x,y in xylist[:-1]]\r\n    try:\r\n        return PolyCurve.CloseWithLine(PolyCurve.ByPoints(points))\r\n    except:\r\n        return PolyCurve.CloseWithLine(PolyCurve.ByPoints(points))\r\n\r\ndef unique_pts(pts, tol=1e-9):\r\n    seen = set()\r\n    out = []\r\n    for x,y in pts:\r\n        key = (round(x/tol)*tol, round(y/tol)*tol)\r\n        if key not in seen:\r\n            seen.add(key)\r\n            out.append((x,y))\r\n    return out\r\n\r\ndef separation_segment(pts, n, t, v_dir):\r\n    inters = []\r\n    for i in range(len(pts)-1):\r\n        P = pts[i]\r\n        Q = pts[i+1]\r\n        dP = dot(n, P) - t\r\n        dQ = dot(n, Q) - t\r\n        if abs(dP) < 1e-12:\r\n            inters.append(P)\r\n        if abs(dQ) < 1e-12:\r\n            inters.append(Q)\r\n        if dP * dQ < 0:\r\n            s = dP / (dP - dQ)\r\n            inter = add(P, mul(sub(Q,P), s))\r\n            inters.append(inter)\r\n\r\n    inters = unique_pts(inters, tol=1e-9)\r\n    if len(inters) < 2:\r\n        return None, None\r\n\r\n    projs = [(dot(v_dir, p), p) for p in inters]\r\n    p_start = min(projs, key=lambda x: x[0])[1]\r\n    p_end   = max(projs, key=lambda x: x[0])[1]\r\n\r\n    return Point.ByCoordinates(p_start[0], p_start[1], 0), Point.ByCoordinates(p_end[0], p_end[1], 0)\r\n\r\ndef process_one(item):\r\n    pts = to_point_list(item)\r\n    if not pts or len(pts) < 3:\r\n        return {\"polyA\": None, \"polyB\": None, \"sepLine\": None}\r\n\r\n    if pts[0] != pts[-1]:\r\n        pts = pts[:]\r\n        pts.append(pts[0])\r\n\r\n    maxlen = -1.0\r\n    maxdir = (1.0, 0.0)\r\n    for i in range(len(pts)-1):\r\n        a = pts[i]\r\n        b = pts[i+1]\r\n        v = sub(b,a)\r\n        l = length(v)\r\n        if l > maxlen:\r\n            maxlen = l\r\n            if l > 0:\r\n                maxdir = (v[0]/l, v[1]/l)\r\n\r\n    v = maxdir\r\n    n = (-v[1], v[0])\r\n\r\n    total_area = polygon_area(pts)\r\n\r\n    projs = [dot(n, p) for p in pts[:-1]]\r\n    pmin = min(projs) - 1e-6\r\n    pmax = max(projs) + 1e-6\r\n\r\n    target = total_area * 0.5\r\n    lo = pmin\r\n    hi = pmax\r\n    for _ in range(60):\r\n        t = (lo + hi) / 2.0\r\n        left_poly = clip_halfspace(pts, n, t)\r\n        a_left = polygon_area(left_poly) if len(left_poly) >= 4 else 0.0\r\n        if a_left > target:\r\n            hi = t\r\n        else:\r\n            lo = t\r\n\r\n    t = (lo + hi) / 2.0\r\n    polyA_pts = clip_halfspace(pts, n, t)\r\n    negn = (-n[0], -n[1])\r\n    polyB_pts = clip_halfspace(pts, negn, -t)\r\n\r\n    polyA = make_polycurve_from_xy(polyA_pts)\r\n    polyB = make_polycurve_from_xy(polyB_pts)\r\n\r\n    p0, p1 = separation_segment(pts, n, t, v)\r\n    sep_line = Line.ByStartPointEndPoint(p0, p1) if p0 and p1 else None\r\n\r\n    return {\"poly\": [polyA, polyB], \"line\": sep_line}\r\n\r\n# single item -> dict, list of items -> list of dicts\r\nif isinstance(src, list) and to_point_list(src) is None:\r\n    OUT = [process_one(s) for s in src]\r\nelse:\r\n    OUT = process_one(src)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "3d6dc4e639734a8eb6fbe8a85a9fb21a",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "2a437a2b5c06422db1e1d1fe8d02bb16",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "be777a99d2554a69b72871465ab149ea",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
