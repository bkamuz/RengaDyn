    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python script\r\n# Split a closed polycurve (polygon) into two polygons of equal area.\r\n# The split line is parallel to the longest polygon edge.\r\n# Inputs:\r\n#   IN[0] : polygon (Autodesk.DesignScript Geometry Polygon / PolyCurve) or list of points\r\n# Output:\r\n#   OUT[0] : polygon A (Dynamo Polygon)\r\n#   OUT[1] : polygon B (Dynamo Polygon)\r\n\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import Point, Polygon, PolyCurve\r\n\r\n# read input\r\nsrc = IN[0]\r\n\r\n# helpers to extract 2D point tuples from several possible input shapes\r\ndef to_point_list(obj):\r\n    # if it's already a list of Dynamo Points\r\n    try:\r\n        if isinstance(obj, list) and len(obj)>0 and hasattr(obj[0], 'X'):\r\n            return [(p.X, p.Y) for p in obj]\r\n    except:\r\n        pass\r\n    # if it's a Dynamo Polygon or PolyCurve with Vertices/Points\r\n    try:\r\n        pts = []\r\n        if hasattr(obj, \"Vertices\"):\r\n            for v in obj.Vertices:\r\n                pts.append((v.X, v.Y))\r\n            return pts\r\n        if hasattr(obj, \"Points\"):\r\n            for v in obj.Points:\r\n                pts.append((v.X, v.Y))\r\n            return pts\r\n    except:\r\n        pass\r\n    # maybe it's a single curve exposing Coordinates\r\n    try:\r\n        if hasattr(obj, \"Coordinates\"):\r\n            return [(c.X, c.Y) for c in obj.Coordinates]\r\n    except:\r\n        pass\r\n    # fallback: if given as list of tuples already\r\n    if isinstance(obj, list) and len(obj)>0 and isinstance(obj[0], (tuple, list)):\r\n        return [(float(x), float(y)) for x,y in obj]\r\n    return None\r\n\r\npts = to_point_list(src)\r\nif not pts or len(pts) < 3:\r\n    OUT = [src, None]\r\nelse:\r\n    # ensure polygon is closed (last != first)\r\n    if pts[0] != pts[-1]:\r\n        pts = pts[:]\r\n        pts.append(pts[0])\r\n\r\n    # vector helpers\r\n    def sub(a,b): return (a[0]-b[0], a[1]-b[1])\r\n    def add(a,b): return (a[0]+b[0], a[1]+b[1])\r\n    def mul(a,s): return (a[0]*s, a[1]*s)\r\n    def dot(a,b): return a[0]*b[0] + a[1]*b[1]\r\n    def length(a): \r\n        import math\r\n        return math.hypot(a[0], a[1])\r\n\r\n    # find longest edge direction\r\n    maxlen = -1.0\r\n    maxdir = (1.0, 0.0)\r\n    for i in range(len(pts)-1):\r\n        a = pts[i]\r\n        b = pts[i+1]\r\n        v = sub(b,a)\r\n        l = length(v)\r\n        if l > maxlen:\r\n            maxlen = l\r\n            if l > 0:\r\n                maxdir = (v[0]/l, v[1]/l)\r\n\r\n    # unit direction parallel to longest edge\r\n    v = maxdir\r\n    # normal direction (perpendicular) we will move along to place the cut\r\n    n = (-v[1], v[0])\r\n\r\n    # polygon area (shoelace), expects closed polygon (last repeats first)\r\n    def polygon_area(poly):\r\n        a = 0.0\r\n        for i in range(len(poly)-1):\r\n            x1,y1 = poly[i]\r\n            x2,y2 = poly[i+1]\r\n            a += x1*y2 - x2*y1\r\n        return abs(a) * 0.5\r\n\r\n    total_area = polygon_area(pts)\r\n\r\n    # clip polygon to half-space defined by n·p <= t (Sutherland-Hodgman)\r\n    def clip_halfspace(poly, nvec, t):\r\n        res = []\r\n        for i in range(len(poly)-1):\r\n            P = poly[i]\r\n            Q = poly[i+1]\r\n            dP = dot(nvec, P) - t\r\n            dQ = dot(nvec, Q) - t\r\n            # if P inside, include\r\n            if dP <= 0:\r\n                res.append(P)\r\n            # edge crosses boundary?\r\n            if dP * dQ < 0:\r\n                # compute intersection\r\n                s = dP / (dP - dQ)\r\n                inter = add(P, mul(sub(Q,P), s))\r\n                res.append(inter)\r\n        # close if not empty\r\n        if len(res) > 0 and res[0] != res[-1]:\r\n            res.append(res[0])\r\n        return res\r\n\r\n    # compute projection min/max for search range\r\n    projs = [dot(n, p) for p in pts[:-1]]\r\n    pmin = min(projs) - 1e-6\r\n    pmax = max(projs) + 1e-6\r\n\r\n    # bisection search for t where left area approx equals half\r\n    target = total_area * 0.5\r\n    lo = pmin\r\n    hi = pmax\r\n    t = (lo + hi) / 2.0\r\n    for _ in range(60):\r\n        t = (lo + hi) / 2.0\r\n        left_poly = clip_halfspace(pts, n, t)\r\n        a_left = polygon_area(left_poly) if len(left_poly) >= 4 else 0.0\r\n        if a_left > target:\r\n            hi = t\r\n        else:\r\n            lo = t\r\n\r\n    t = (lo + hi) / 2.0\r\n    polyA_pts = clip_halfspace(pts, n, t)       # n·p <= t\r\n    # other half: clip by opposite half-space (n·p >= t) => clip with -n and -t for <= form\r\n    negn = (-n[0], -n[1])\r\n    polyB_pts = clip_halfspace(pts, negn, -t)\r\n\r\n    # construct Dynamo polygons (Polygon.ByPoints expects list of Point)\r\n    def make_polycurve_from_xy(xylist):\r\n        if not xylist or len(xylist) < 4:\r\n            return None\r\n        points = [Point.ByCoordinates(x,y,0) for x,y in xylist[:-1]]  # exclude duplicated last\r\n        try:\r\n            return PolyCurve.ByPoints(points)\r\n        except:\r\n            # fallback to polycurve via creating closed point list\r\n            return PolyCurve.ByPoints(points)\r\n\r\n    polyA = make_polycurve_from_xy(polyA_pts)\r\n    polyB = make_polycurve_from_xy(polyB_pts)\r\n\r\n    OUT = [polyA, polyB]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "0add49a4942546a89ea70b6fffa820fa",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "9345021ec3a94ce39d2ed61914188d4a",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "b21d3b327c8740b7bd2de4e1b1b988e4",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
