    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "38fa5d43afba4830aad382884d5dc66d",
      "NodeType": "CodeBlockNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "2746f7985f9e4b16bd6233bcf7a60c45",
          "Name": "double",
          "Description": "0.01",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
