      ],
      "FunctionSignature": "DSCore.List.AllTrue@var[]..[]",
      "Replication": "Longest",
      "Description": "Determines if all items in the given list is a boolean and has a true value.\n\nList.AllTrue (list: var[]..[]): bool"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Вход: IN[0] — список пар или одиночная пара\r\npairs_in = IN[0]\r\n\r\ndef normalize_input(p):\r\n    if p is None:\r\n        return []\r\n    try:\r\n        # если передали одну пару [a, b]\r\n        if isinstance(p, (list, tuple)) and len(p) > 0 and not isinstance(p[0], (list, tuple)):\r\n            return [p[:2]] if len(p) >= 2 else []\r\n        return list(p)\r\n    except Exception:\r\n        return []\r\n\r\ndef to_int_safe(x):\r\n    try:\r\n        return int(x)\r\n    except Exception:\r\n        return None\r\n\r\ndef good_pair(pair):\r\n    try:\r\n        a, b = pair\r\n    except Exception:\r\n        return False\r\n    a = to_int_safe(a)\r\n    b = to_int_safe(b)\r\n    if a is None or b is None:\r\n        return False\r\n    if a == b:\r\n        return True\r\n    mn = min(abs(a), abs(b))\r\n    mx = max(abs(a), abs(b))\r\n    if mn == 0:\r\n        return False\r\n    if mn == 1:\r\n        return False\r\n    return mx % mn == 0\r\n\r\npairs = normalize_input(pairs_in)\r\nmask = [good_pair(p) for p in pairs]\r\nfiltered = [p for p, ok in zip(pairs, mask) if ok]\r\n\r\nOUT = mask\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "fe539b6c6ec142e8b60b2bc7f400e10b",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "d87ff72706b44f5d831e4e633e685e32",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "f8c7b179d21a4b489c3b641f4fb0403c",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
