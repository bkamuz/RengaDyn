    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "Id": "5d46d7bfa14545c4ad227c640a60a628",
      "NodeType": "FunctionNode",
      "Inputs": [
        {
          "Id": "69a4b30a39904b4b867d84ceb2e861a2",
          "Name": "curve2D",
          "Description": "DynRenga.RengaAPI.ICurve2D to convert\n\nICurve2D",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b54bdd40dbdb4f658c5584cd537168ef",
          "Name": "partsPerMeter",
          "Description": "Number of points per meter for curve discretization (default: 2)\n\nint\nDefault value : 2",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "3c316a3eda6647499166d77a89471cf6",
          "Name": "PolyCurve",
          "Description": "Dynamo PolyCurve representing the curve",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "FunctionSignature": "DynRenga.Converters.Renga.Curve2DConverter.ToDynamoPolyCurveOptimized@DynRenga.RengaAPI.ICurve2D,int",
      "Replication": "Auto",
      "Description": "Converts DynRenga.RengaAPI.ICurve2D to Dynamo PolyCurve with optimized handling for closed curves\n\nCurve2DConverter.ToDynamoPolyCurveOptimized (curve2D: ICurve2D, partsPerMeter: int = 2): PolyCurve"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nB_IN = IN[0]\r\nSPLITTERS_IN = IN[1] if len(IN) > 1 and IN[1] is not None else []\r\nEXT = 0.0\r\nEPS = 1e-6\r\n\r\ndef flatten(lst):\r\n    out = []\r\n    for x in lst if isinstance(lst, (list, tuple)) else [lst]:\r\n        if isinstance(x, (list, tuple)):\r\n            out.extend(flatten(x))\r\n        else:\r\n            out.append(x)\r\n    return out\r\n\r\ndef to_polycurve_loose(g):\r\n    if isinstance(g, PolyCurve):\r\n        try:\r\n            return PolyCurve.ByJoinedCurves(g.Curves())\r\n        except:\r\n            return g\r\n    if isinstance(g, Polygon):\r\n        return PolyCurve.ByJoinedCurves(list(g.Curves()))\r\n    if isinstance(g, Surface):\r\n        try:\r\n            return PolyCurve.ByJoinedCurves(g.PerimeterCurves())\r\n        except:\r\n            pass\r\n    if isinstance(g, Curve):\r\n        return PolyCurve.ByJoinedCurves([g])\r\n    if isinstance(g, (list, tuple)):\r\n        cs = [c for c in flatten(g) if isinstance(c, Curve)]\r\n        if cs:\r\n            return PolyCurve.ByJoinedCurves(cs)\r\n    return None\r\n\r\ndef uniq(vals, tol=1e-6):\r\n    vs = sorted(vals)\r\n    out = []\r\n    for v in vs:\r\n        if not out or abs(v - out[-1]) > tol:\r\n            out.append(v)\r\n    return out\r\n\r\ndef bbox_of_polycurve(pc):\r\n    try:\r\n        return pc.BoundingBox\r\n    except:\r\n        minx=miny=1e99; maxx=maxy=-1e99\r\n        for c in pc.Curves():\r\n            for p in [c.StartPoint, c.EndPoint]:\r\n                minx=min(minx,p.X); maxx=max(maxx,p.X)\r\n                miny=min(miny,p.Y); maxy=max(maxy,p.Y)\r\n        return BoundingBox.ByCorners(Point.ByCoordinates(minx,miny,0), Point.ByCoordinates(maxx,maxy,0))\r\n\r\ndef collect_vertices(pc):\r\n    pts = []\r\n    try:\r\n        pts = pc.Points()\r\n    except:\r\n        for c in pc.Curves():\r\n            try:\r\n                pts.append(c.StartPoint)\r\n            except:\r\n                pass\r\n        try:\r\n            pts.append(pc.Curves()[-1].EndPoint)\r\n        except:\r\n            pass\r\n    return pts\r\n\r\ndef point_in_polygon(px, py, verts, eps=1e-9):\r\n    inside = False\r\n    n = len(verts)\r\n    if n < 3: return False\r\n    py_adj = py - eps\r\n    for i in range(n-1):\r\n        x1,y1 = verts[i]; x2,y2 = verts[i+1]\r\n        if abs(y1-y2) <= eps:\r\n            if min(x1,x2)-eps <= px <= max(x1,x2)+eps and abs(py - y1) <= eps:\r\n                return True\r\n            continue\r\n        ymin = min(y1,y2); ymax = max(y1,y2)\r\n        if not (ymin - eps <= py_adj < ymax - eps): continue\r\n        xint = (x2-x1)*(py_adj - y1)/(y2-y1) + x1\r\n        if abs(px - xint) <= eps: return True\r\n        if px < xint: inside = not inside\r\n    return inside\r\n\r\ndef is_horizontal(line, tol=1e-6):\r\n    return abs(line.StartPoint.Y - line.EndPoint.Y) < tol\r\n\r\ndef is_vertical(line, tol=1e-6):\r\n    return abs(line.StartPoint.X - line.EndPoint.X) < tol\r\n\r\nDEBUG = {\"steps\": []}\r\ndef log(m): DEBUG[\"steps\"].append(str(m))\r\n\r\npc = to_polycurve_loose(B_IN)\r\nif pc is None:\r\n    OUT = [[], {\"error\":\"Could not interpret IN[0] as curves/polycurve\", \"steps\": DEBUG[\"steps\"]}]\r\nelse:\r\n    # Get boundary info\r\n    is_closed = getattr(pc, \"IsClosed\", None)\r\n    crv_count = len(pc.Curves()) if hasattr(pc, \"Curves\") else None\r\n    log(\"PolyCurve built. IsClosed=%s, Curves=%s\" % (str(is_closed), str(crv_count)))\r\n\r\n    # Get boundary vertices\r\n    pts = collect_vertices(pc)\r\n    Xs = [p.X for p in pts]\r\n    Ys = [p.Y for p in pts]\r\n    \r\n    # Get bounding box\r\n    bb = bbox_of_polycurve(pc)\r\n    minp, maxp = bb.MinPoint, bb.MaxPoint\r\n    xmin, xmax = minp.X, maxp.X\r\n    ymin, ymax = minp.Y, maxp.Y\r\n\r\n    # Create splitters from input splitters + internal coordinates\r\n    splitters = []\r\n    \r\n    # Add user-provided splitters\r\n    if SPLITTERS_IN:\r\n        user_splitters = flatten(SPLITTERS_IN)\r\n        for ln in user_splitters:\r\n            if isinstance(ln, Curve):\r\n                splitters.append(ln)\r\n    \r\n    # Add internal X coordinates (exclude boundary edges)\r\n    internal_xs = []\r\n    for x in uniq(Xs):\r\n        if x > xmin + EPS and x < xmax - EPS:  # Internal only\r\n            internal_xs.append(x)\r\n    \r\n    # Add internal Y coordinates (exclude boundary edges)  \r\n    internal_ys = []\r\n    for y in uniq(Ys):\r\n        if y > ymin + EPS and y < ymax - EPS:  # Internal only\r\n            internal_ys.append(y)\r\n    \r\n    # Create vertical splitters for internal X coordinates\r\n    for x in internal_xs:\r\n        splitters.append(Line.ByStartPointEndPoint(\r\n            Point.ByCoordinates(x, ymin, 0), \r\n            Point.ByCoordinates(x, ymax, 0)\r\n        ))\r\n    \r\n    # Create horizontal splitters for internal Y coordinates\r\n    for y in internal_ys:\r\n        splitters.append(Line.ByStartPointEndPoint(\r\n            Point.ByCoordinates(xmin, y, 0), \r\n            Point.ByCoordinates(xmax, y, 0)\r\n        ))\r\n\r\n    # Extract X and Y levels from all splitters\r\n    x_levels = [xmin, xmax]\r\n    y_levels = [ymin, ymax]\r\n    \r\n    for ln in splitters:\r\n        if is_vertical(ln):\r\n            x_levels.append(ln.StartPoint.X)\r\n        elif is_horizontal(ln):\r\n            y_levels.append(ln.StartPoint.Y)\r\n    \r\n    x_levels = uniq(x_levels, EPS)\r\n    y_levels = uniq(y_levels, EPS)\r\n    \r\n    # Get boundary vertices for containment test\r\n    verts = [(p.X, p.Y) for p in pts]\r\n    \r\n    # Create rectangular zones\r\n    zones = []\r\n    for yi in range(len(y_levels)-1):\r\n        y0, y1 = y_levels[yi], y_levels[yi+1]\r\n        for xi in range(len(x_levels)-1):\r\n            x0, x1 = x_levels[xi], x_levels[xi+1]\r\n            \r\n            # Test if rectangle center is inside boundary\r\n            cx, cy = 0.5*(x0+x1), 0.5*(y0+y1)\r\n            if point_in_polygon(cx, cy, verts):\r\n                # Create rectangle\r\n                bl = Point.ByCoordinates(x0, y0, 0)\r\n                br = Point.ByCoordinates(x1, y0, 0)\r\n                tr = Point.ByCoordinates(x1, y1, 0)\r\n                tl = Point.ByCoordinates(x0, y1, 0)\r\n                rect = PolyCurve.ByPoints([bl, br, tr, tl, bl])\r\n                zones.append(rect)\r\n\r\n    DEBUG.update({\r\n        \"isClosed_reported\": is_closed,\r\n        \"curve_count\": crv_count,\r\n        \"vertex_count\": len(pts),\r\n        \"internal_X\": internal_xs,\r\n        \"internal_Y\": internal_ys,\r\n        \"splitters_count\": len(splitters),\r\n        \"x_levels\": x_levels,\r\n        \"y_levels\": y_levels,\r\n        \"zones_created\": len(zones)\r\n    })\r\n\r\n    OUT = [zones, DEBUG]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "f755961cef454f999e0e954d80d5562f",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "67fb4fc005e24eb09072d5bab9dfb364",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "edcbe4baa4f2431ba13a4d9e7ca161c2",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nEPS = 1e-6\r\n\r\ndef uniq_sorted(vals, tol=1e-6):\r\n    vals = sorted(vals); out = []\r\n    for v in vals:\r\n        if not out or abs(v - out[-1]) > tol: out.append(v)\r\n    return out\r\n\r\ndef get_local_cs(pc):\r\n    # Нормализация вектора вручную (в некоторых сборках нет Normalize/Normalized)\r\n    def unit(v):\r\n        try:\r\n            L = v.Length\r\n        except:\r\n            # если внезапно пришёл не Vector\r\n            return v\r\n        if L == 0: \r\n            return v\r\n        return Vector.ByCoordinates(v.X / L, v.Y / L, v.Z / L)\r\n\r\n    # 1) пробуем через Surface.ByPatch\r\n    try:\r\n        srf = Surface.ByPatch(pc)\r\n        cs0 = srf.CoordinateSystemAtParameter(0.5, 0.5)\r\n        try: srf.Dispose()\r\n        except: pass\r\n    except:\r\n        # 2) fallback: best-fit plane\r\n        pts = [c.StartPoint for c in pc.Curves()]\r\n        pl = Plane.ByBestFitThroughPoints(pts)\r\n        cs0 = CoordinateSystem.ByPlane(pl)\r\n        for p in pts:\r\n            try: p.Dispose()\r\n            except: pass\r\n        try: pl.Dispose()\r\n        except: pass\r\n\r\n    # 3) собираем оси как СВОЙСТВА (не вызываем!)\r\n    o = cs0.Origin\r\n    x = unit(cs0.XAxis)\r\n    y = unit(cs0.YAxis)\r\n    z = unit(cs0.ZAxis)\r\n\r\n    # 4) возвращаем корректную КС\r\n    return CoordinateSystem.ByOriginVectors(o, x, y, z)\r\n\r\ndef to_local_point(pt, cs):\r\n    p = pt.Transform(cs.Inverse())\r\n    return p.X, p.Y, p.Z\r\n\r\ndef boundary_xy_local(pc, cs):\r\n    verts = []\r\n    for crv in pc.Curves():\r\n        x,y,_ = to_local_point(crv.StartPoint, cs)\r\n        verts.append((x,y))\r\n    xe, ye, _ = to_local_point(pc.Curves()[-1].EndPoint, cs)\r\n    if abs(verts[0][0]-xe)>EPS or abs(verts[0][1]-ye)>EPS:\r\n        verts.append((xe,ye))\r\n    return verts\r\n\r\n# --- winding number (устойчивее на вершинах) ---\r\ndef wn_point_in_poly(px, py, V, eps=1e-9):\r\n    wn = 0\r\n    n = len(V)-1\r\n    for i in range(n):\r\n        x1,y1 = V[i]; x2,y2 = V[i+1]\r\n        # точка на ребре\r\n        if (min(x1,x2)-eps <= px <= max(x1,x2)+eps and\r\n            min(y1,y2)-eps <= py <= max(y1,y2)+eps):\r\n            if abs((x2-x1)*(py-y1) - (y2-y1)*(px-x1)) <= eps:\r\n                return True\r\n        if y1 <= py:\r\n            if y2 > py and (x2-x1)*(py-y1) - (y2-y1)*(px-x1) > 0: wn += 1\r\n        else:\r\n            if y2 <= py and (x2-x1)*(py-y1) - (y2-y1)*(px-x1) < 0: wn -= 1\r\n    return wn != 0\r\n\r\ndef orient(ax,ay,bx,by,cx,cy):\r\n    return (bx-ax)*(cy-ay) - (by-ay)*(cx-ax)\r\n\r\ndef segments_intersect(a,b,c,d, tol=1e-9, touch_ok=True):\r\n    ax,ay=a; bx,by=b; cx,cy=c; dx,dy=d\r\n    o1 = orient(ax,ay,bx,by,cx,cy); o2 = orient(ax,ay,bx,by,dx,dy)\r\n    o3 = orient(cx,cy,dx,dy,ax,ay); o4 = orient(cx,cy,dx,dy,bx,by)\r\n    if (o1*o2 < -tol and o3*o4 < -tol): return True\r\n    def onseg(p,q,r):\r\n        px,py=p; qx,qy=q; rx,ry=r\r\n        return (min(px,rx)-tol <= qx <= max(px,rx)+tol and min(py,ry)-tol <= qy <= max(py,ry)+tol)\r\n    if abs(o1)<=tol and onseg(a,c,b): return not touch_ok\r\n    if abs(o2)<=tol and onseg(a,d,b): return not touch_ok\r\n    if abs(o3)<=tol and onseg(c,a,d): return not touch_ok\r\n    if abs(o4)<=tol and onseg(c,b,d): return not touch_ok\r\n    return False\r\n\r\ndef rect_inside_strict(x0,y0,x1,y1, V):\r\n    # динамический inset от размера ячейки\r\n    w = abs(x1-x0); h = abs(y1-y0)\r\n    fc = max(0.008, 0.5*EPS/max(w,h,1.0))  # ~0.8% или чуть больше эпсилон/размер\r\n    fe = fc*0.5\r\n    cx,cy = 0.5*(x0+x1), 0.5*(y0+y1)\r\n    # углы + середины рёбер, сдвинутые внутрь\r\n    corners = [(x0+(cx-x0)*fc, y0+(cy-y0)*fc),\r\n               (x1+(cx-x1)*fc, y0+(cy-y0)*fc),\r\n               (x1+(cx-x1)*fc, y1+(cy-y1)*fc),\r\n               (x0+(cx-x0)*fc, y1+(cy-y1)*fc)]\r\n    edges = [(0.5*(x0+x1)+(cx-0.5*(x0+x1))*fe, y0+(cy-y0)*fe),\r\n             (x1+(cx-x1)*fe, 0.5*(y0+y1)+(cy-0.5*(y0+y1))*fe),\r\n             (0.5*(x0+x1)+(cx-0.5*(x0+x1))*fe, y1+(cy-y1)*fe),\r\n             (x0+(cx-x0)*fe, 0.5*(y0+y1)+(cy-0.5*(y0+y1))*fe)]\r\n    if not all(wn_point_in_poly(px,py,V) for (px,py) in corners+edges+[ (cx,cy) ]):\r\n        return False\r\n    # рёбра прямоугольника не должны пересекать границу (кроме касания)\r\n    re = [((x0,y0),(x1,y0)), ((x1,y0),(x1,y1)), ((x1,y1),(x0,y1)), ((x0,y1),(x0,y0))]\r\n    for i in range(len(V)-1):\r\n        e = (V[i], V[i+1])\r\n        for r in re:\r\n            if segments_intersect(r[0], r[1], e[0], e[1], tol=1e-9, touch_ok=True):\r\n                # легкое вдвигание внутрь и повторная проверка\r\n                (px1,py1),(px2,py2) = r\r\n                px1i,py1i = (px1+(cx-px1)*1e-4, py1+(cy-py1)*1e-4)\r\n                px2i,py2i = (px2+(cx-px2)*1e-4, py2+(cy-py2)*1e-4)\r\n                if segments_intersect((px1i,py1i),(px2i,py2i), e[0], e[1], tol=1e-9, touch_ok=True):\r\n                    return False\r\n    return True\r\n\r\n# ---------- Inputs ----------\r\nboundary = IN[0]\r\nsplitters_in = IN[1] if len(IN)>1 else None\r\nif splitters_in and not isinstance(splitters_in, list): splitters_in=[splitters_in]\r\n\r\nif not boundary:\r\n    OUT=[]\r\nelse:\r\n    cs = get_local_cs(boundary)\r\n    V = boundary_xy_local(boundary, cs)\r\n    if V[0]!=V[-1]: V.append(V[0])\r\n\r\n    # уровни: все X/Y вершин + из сплиттеров (поддержка линий и точек)\r\n    x_levels = [x for x,_ in V]\r\n    y_levels = [y for _,y in V]\r\n    if splitters_in:\r\n        for g in splitters_in:\r\n            if isinstance(g, Curve):\r\n                x1,y1,_=to_local_point(g.StartPoint, cs); x2,y2,_=to_local_point(g.EndPoint, cs)\r\n                if abs(x1-x2)<1e-6 and abs(y1-y2)<1e-6:\r\n                    x_levels.append(x1); y_levels.append(y1)\r\n                else:\r\n                    if abs(x1-x2)<1e-6: x_levels.append(x1)\r\n                    if abs(y1-y2)<1e-6: y_levels.append(y1)\r\n            elif isinstance(g, Point):\r\n                x,y,_=to_local_point(g, cs); x_levels.append(x); y_levels.append(y)\r\n\r\n    x_levels = uniq_sorted(x_levels, EPS)\r\n    y_levels = uniq_sorted(y_levels, EPS)\r\n\r\n    # генерим зоны\r\n    zones=[]\r\n    for yi in range(len(y_levels)-1):\r\n        y0,y1 = y_levels[yi], y_levels[yi+1]\r\n        for xi in range(len(x_levels)-1):\r\n            x0,x1 = x_levels[xi], x_levels[xi+1]\r\n            if rect_inside_strict(x0,y0,x1,y1, V):\r\n                bl=Point.ByCartesianCoordinates(cs,x0,y0,0)\r\n                br=Point.ByCartesianCoordinates(cs,x1,y0,0)\r\n                tr=Point.ByCartesianCoordinates(cs,x1,y1,0)\r\n                tl=Point.ByCartesianCoordinates(cs,x0,y1,0)\r\n                zones.append(PolyCurve.ByPoints([bl,br,tr,tl,bl]))\r\n\r\n    OUT = zones",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "b3deef2588ad4f0da8ae8c62c82c9bd8",
      "NodeType": "PythonScriptNode",
      "Inputs": [
