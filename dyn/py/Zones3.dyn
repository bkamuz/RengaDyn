        }
      ],
      "Outputs": [
        {
          "Id": "ceb0081ce3e4426b951c87b07fce20bb",
          "Name": "has_points",
          "Description": "has_points",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
