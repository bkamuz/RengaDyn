    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "6eccef1f3c0a46fabd9a9e95af51b152",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        {
          "Id": "9ac5aadb01f142fb8f82251f28fc7342",
          "Name": "has_points",
