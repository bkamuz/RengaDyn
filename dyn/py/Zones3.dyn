    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "d882193ea6c542cd9479c3474fba9b2e",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        {
          "Id": "6dcac88b15944d7b97e6af5a617098f4",
          "Name": "contour_mainBaseline",
          "Description": "contour_mainBaseline",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
